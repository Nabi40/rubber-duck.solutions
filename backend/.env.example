# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=backend.rubber-duck.solutions,localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://DB_USER:DB_PASS@DB_HOST:5432/DB_NAME

# CORS
CORS_ALLOWED_ORIGINS=https://www.rubber-duck.solutions,https://rubber-duck.solutions,http://localhost:3000

# If you are behind a proxy (Nginx/Cloudflare)
SECURE_PROXY_SSL_HEADER=True